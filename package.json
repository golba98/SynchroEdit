{
  "name": "1-synchroedit",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "cross-env SKIP_DB_SETUP=true jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "playwright test",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint . -c config/.eslintrc.json --ignore-path config/.eslintignore",
    "format": "prettier --write . --config config/.prettierrc --ignore-path config/.prettierignore"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ],
    "setupFiles": [
      "./tests/env.js"
    ],
    "testEnvironment": "node",
    "maxWorkers": 1,
    "moduleNameMapper": {
      "^/js/(.*)$": "<rootDir>/public/js/$1",
      "^y-websocket$": "<rootDir>/tests/mocks/emptyModule.js",
      "^y-quill$": "<rootDir>/tests/mocks/emptyModule.js",
      "^https://unpkg.com/idb-keyval@(.*)$": "idb-keyval"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/golba98-dev/SynchroEdit.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/golba98-dev/SynchroEdit/issues"
  },
  "homepage": "https://github.com/golba98-dev/SynchroEdit#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "geoip-lite": "^2.0.1",
    "helmet": "^8.1.0",
    "idb-keyval": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.2",
    "nodemailer": "^8.0.4",
    "ua-parser-js": "^2.0.9",
    "winston": "^3.19.0",
    "ws": "^8.20.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.28"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@playwright/browser-chromium": "^1.57.0",
    "@playwright/test": "^1.57.0",
    "babel-jest": "^30.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
